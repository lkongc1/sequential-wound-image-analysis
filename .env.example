# ============================================================
# Environment Variables — Example
# Copy this file to .env and adjust values for your setup.
# ============================================================

# Data paths
DATA_DIR=data/raw/data_wound_seg
OUTPUT_DIR=output/train_results
MODEL_DIR=models
METADATA_PATH=data/metadata_enriched.csv

# Model configuration
ENCODER=resnet34
ENCODER_WEIGHTS=imagenet
IMAGE_SIZE=384
BATCH_SIZE=6
EPOCHS=100
LEARNING_RATE=1e-4
PATIENCE=15

# Device (cuda / cpu)
DEVICE=cuda

# API configuration
API_HOST=0.0.0.0
API_PORT=8000

# Keep only the processed CSVs needed for training
!data-clasificador/train.csv
!data-clasificador/val.csv
!data-clasificador/test.csv

# ============================================================
# Models — checkpoints and training artifacts
# ============================================================
# Ignorar checkpoints de entrenamiento y screening (son grandes, regenerables)
models/checkpoints/
models/general/
models/screening/
models/classifier/*.ckpt
models/classifier/last*.ckpt
models/classifier/logs/
models/classifier/best-epoch*/
models/classifier/v*/

# SAM2 descarga pesos automáticamente (~900MB)
models/sam2/

# Trackear solo modelos de comparativa (usados para evaluación)
# models/comparativa/ NO está ignorado — se trackea completo
# y el mejor checkpoint del clasificador
!models/classifier/best.pth

# Generated pseudo-masks alongside original images
*_mask.png

# Inference result temporary directories
scripts/inference/resultados_v*/

